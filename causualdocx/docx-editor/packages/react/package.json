{
  "name": "@casualoffice/docs",
  "version": "1.1.7",
  "description": "A browser-based DOCX template editor with variable insertion support",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.mjs",
      "require": "./dist/react.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.mjs",
      "require": "./dist/ui.js"
    },
    "./core": {
      "types": "./dist/core-reexport.d.ts",
      "import": "./dist/core-reexport.mjs",
      "require": "./dist/core-reexport.js"
    },
    "./headless": {
      "types": "./dist/headless-reexport.d.ts",
      "import": "./dist/headless-reexport.mjs",
      "require": "./dist/headless-reexport.js"
    },
    "./core-plugins": {
      "types": "./dist/core-plugins-reexport.d.ts",
      "import": "./dist/core-plugins-reexport.mjs",
      "require": "./dist/core-plugins-reexport.js"
    },
    "./mcp": {
      "types": "./dist/mcp-reexport.d.ts",
      "import": "./dist/mcp-reexport.mjs",
      "require": "./dist/mcp-reexport.js"
    },
    "./styles.css": "./dist/styles.css",
    "./embed-runtime": {
      "types": "./dist/embed/embed-runtime.d.mts",
      "import": "./dist/embed/embed-runtime.mjs"
    },
    "./embed/embed.html": "./dist/embed/embed.html",
    "./embed/embed-runtime.css": "./dist/embed/embed-runtime.css",
    "./i18n/*.json": "./i18n/*.json"
  },
  "typesVersions": {
    "*": {
      "react": [
        "./dist/react.d.ts"
      ],
      "ui": [
        "./dist/ui.d.ts"
      ],
      "core": [
        "./dist/core-reexport.d.ts"
      ],
      "headless": [
        "./dist/headless-reexport.d.ts"
      ],
      "core-plugins": [
        "./dist/core-plugins-reexport.d.ts"
      ],
      "mcp": [
        "./dist/mcp-reexport.d.ts"
      ]
    }
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "i18n"
  ],
  "scripts": {
    "build": "tsup && bun run build:fonts && bun run build:css && bun run build:embed-css",
    "build:fonts": "mkdir -p dist/fonts && cp src/styles/fonts/*.woff2 src/styles/fonts/LICENSE dist/fonts/",
    "build:css": "tailwindcss -c ../../tailwind.config.lib.js -i ./src/styles/editor.css -o ./dist/styles.css --minify",
    "build:embed-css": "node -e \"const fs=require('fs'); const base=fs.existsSync('dist/embed/embed-runtime.css')?fs.readFileSync('dist/embed/embed-runtime.css','utf8'):''; const editor=fs.readFileSync('dist/styles.css','utf8').replace(/url\\(fonts\\//g,'url(../fonts/'); fs.writeFileSync('dist/embed/embed-runtime.css', base + '\\n' + editor);\"",
    "prepublishOnly": "bun run build && sed -e 's|\\./assets/|https://raw.githubusercontent.com/eigenpal/docx-editor/main/assets/|g' -e 's|(packages/|(https://github.com/eigenpal/docx-editor/tree/main/packages/|g' -e 's|(docs/|(https://github.com/eigenpal/docx-editor/blob/main/docs/|g' -e 's|(examples/|(https://github.com/eigenpal/docx-editor/tree/main/examples/|g' ../../README.md > README.md",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@hocuspocus/provider": "^2.15.0",
    "prosemirror-commands": "^1.5.2",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-history": "^1.4.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.19.4",
    "prosemirror-state": "^1.4.3",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.10.2",
    "prosemirror-view": "^1.41.6",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "y-prosemirror": "^1.2.0",
    "y-websocket": "^2.0.0",
    "yjs": "^13.6.0"
  },
  "peerDependenciesMeta": {
    "@hocuspocus/provider": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "y-prosemirror": {
      "optional": true
    },
    "y-websocket": {
      "optional": true
    },
    "yjs": {
      "optional": true
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@mlc-ai/web-llm": "^0.2.84",
    "@radix-ui/react-select": "^2.2.6",
    "@schnsrw/core": "^0.1.1",
    "clsx": "^2.1.0",
    "dictionary-en": "^4.0.0",
    "katex": "^0.17.0",
    "nspell": "^2.1.5",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@hocuspocus/provider": "^2.15.0",
    "@schnsrw/design-system": "file:../../vendor/design-system",
    "@types/katex": "^0.16.8",
    "prosemirror-commands": "^1.5.2",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-history": "^1.4.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.19.4",
    "prosemirror-state": "^1.4.3",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.10.2",
    "prosemirror-view": "^1.41.6",
    "y-prosemirror": "^1.2.0",
    "y-websocket": "^2.0.0",
    "yjs": "^13.6.0"
  },
  "keywords": [
    "docx",
    "editor",
    "template",
    "word",
    "document",
    "react",
    "prosemirror"
  ],
  "author": "EigenPal",
  "license": "MIT",
  "homepage": "https://docx-editor.dev/",
  "repository": {
    "type": "git",
    "url": "https://github.com/CasualOffice/docs.git",
    "directory": "docx-editor/packages/react"
  },
  "publishConfig": {
    "access": "public"
  }
}
