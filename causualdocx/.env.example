# Casual Editor — environment configuration template.
#
# Copy to `.env` and fill in. The bundled Docker image picks safe
# defaults for every variable below; you only need to override the
# values that apply to your deployment.
#
#   cp .env.example .env
#   $EDITOR .env
#   docker compose --env-file .env up
#
# Variables are grouped by which layer reads them.

# ─── Go gateway ────────────────────────────────────────────────────

# TCP address the gateway binds to.
# Default: :8080
GATEWAY_ADDR=:8080

# Directory the gateway serves the editor SPA from. When set, the
# gateway also handles GET / (with an index.html SPA fallback for
# client-side routes like /r/{docId}) so the editor and API share one
# origin. The bundled image sets this to /srv/static. Leave UNSET for
# local dev when Vite serves the SPA on :5173 against the gateway on
# :8080 (different origins; the share dialog embeds the gateway WS
# URL in the share link query string).
# STATIC_DIR=/srv/static


# ─── Editor build (Vite, read at build time) ───────────────────────

# HTTP base for the gateway. Used by the share dialog's upload and
# the seed-download fetch in collab sessions.
#
# Resolution order (in code):
#   1. ?backend=ws(s)://... in the URL (set by share-link generator)
#   2. VITE_BACKEND env at build time
#   3. window.location.origin in production builds (bundled image)
#   4. http://localhost:8080 in dev as a last-resort fallback
#
# Leave unset for the bundled image (same-origin is correct).
# Set this in dev when Vite is on :5173 and the gateway on :8080.
# VITE_BACKEND=http://localhost:8080

# Toggle the Share button. The Pages demo builds with this off
# because there's no gateway behind doc.schnsrw.live. The Docker
# image build sets this to "true".
VITE_COLLAB_ENABLED=true


# ─── Fidelity comparison harness ───────────────────────────────────
# Only consumed by scripts/compare-fidelity.mjs + the
# fidelity-compare.yml CI workflow. Safe to leave commented out
# in normal use.

# Pristine-share floor (0–1). The harness fails the run when our
# pristine fraction drops below this. Raise as gap-matrix items
# close.
# Default: 0.5
# FIDELITY_FLOOR=0.5

# Path to `soffice` if not on PATH. Harness probes a few defaults.
# LIBREOFFICE_BIN=/Applications/LibreOffice.app/Contents/MacOS/soffice

# Override the Docker image tag for OnlyOffice DocumentBuilder.
# Default: onlyoffice/documentbuilder:latest
# ONLYOFFICE_DOCBUILDER_IMAGE=onlyoffice/documentbuilder:7.5.0
